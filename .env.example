# Najim Backend — Required Environment Variables
# Copy to .env and fill in your values.
# =====================================================

# REQUIRED — JWT signing secret (generate with: openssl rand -hex 32)
JWT_SECRET=change_me_to_a_long_random_secret

# REQUIRED — LLM API key (Groq, OpenAI, or compatible)
LLM_API_KEY=gsk_your_groq_api_key_here

# Redis (defaults to embedded redis in docker-compose.yml)
# REDIS_URL=redis://:password@host:6379/0
# REDIS_PASSWORD=najim_pass

# Cluster node identity
CLUSTER_NODE_ID=node-1

# Model paths
# STT_MODEL_NAME=medium
# STT_DEVICE=auto
# TTS_DEFAULT_VOICE=en

# LLM settings
# LLM_MODEL=llama-3.3-70b-versatile
# LLM_API_BASE_URL=https://api.groq.com/openai/v1

# Pipeline workers per stage (default: 1)
# PIPELINE_STT_WORKERS=1
# PIPELINE_LLM_WORKERS=1
# PIPELINE_TTS_WORKERS=1
# PIPELINE_WS_WORKERS=1

# Server
# API_PORT=8080
# LOG_LEVEL=info
# DEBUG=false
